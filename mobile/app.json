{
  "expo": {
    "name": "LifeOS",
    "slug": "lifeos",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "lifeos",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.lifeos.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.lifeos.app",
      "adaptiveIcon": {
